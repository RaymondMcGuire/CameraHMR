# Copy to .env and edit paths for your WSL machine.
#
# Windows path examples:
#   D:\SMPL-project\CameraHMR\data -> /mnt/d/SMPL-project/CameraHMR/data
#   D:\my-images -> /mnt/d/my-images

CAMERAHMR_DATA_DIR=./data
CAMERAHMR_INPUT_DIR=./demo_images
CAMERAHMR_OUTPUT_DIR=./output_images
CAMERAHMR_MODEL_TYPE=smpl

# Optional: narrow this if Detectron2 fails while compiling.
# RTX 5090 / sm_120: 12.0
# RTX 30xx: 8.6
# TORCH_CUDA_ARCH_LIST=12.0
